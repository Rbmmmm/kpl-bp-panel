{
  "name": "kpl-bp-panel",
  "version": "0.1.0",
  "description": "KPL BO7 Ban/Pick desktop simulator.",
  "author": "KPL BP Panel Contributors",
  "main": "dist-electron/electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/electron/main.js",
    "sync:heroes": "node scripts/sync-heroes.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "package": "npm run build && electron-builder --dir",
    "package:mac": "npm run build && electron-builder --mac dir",
    "package:mac:signed": "npm run build && electron-builder --mac dir dmg -c.forceCodeSigning=true",
    "package:mac:release": "npm run build && electron-builder --mac dir dmg -c.forceCodeSigning=true -c.mac.notarize=true",
    "package:win": "npm run build && electron-builder --win nsis",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.kplbppanel.app",
    "productName": "KPL BP Panel",
    "copyright": "Copyright © 2026 KPL BP Panel Contributors",
    "directories": {
      "output": "release"
    },
    "artifactName": "KPL-BP-Panel-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.sports",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "KPL-BP-Panel-${version}-${os}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
